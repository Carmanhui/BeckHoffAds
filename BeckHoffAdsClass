        /// 解析保持型变量
        /// </summary>
        /// <param name="IsStructVar">结构形式</param>
        /// <param name="IsBaseArray">数组整体</param>
        public void ParsePlcSymbols(bool IsStructVar=false,bool IsBaseArray=false)
        {
            try
            {
                PersistantSymbols.Clear();
                PersistantVars.Clear();
                var symbols = SymbolLoaderFactory.Create(tcClient, SymbolLoaderSettings.Default).Symbols;
                foreach (var symbol in symbols)
                {
                    AddPlcSymbols(symbol,IsStructVar,IsBaseArray);
                }
            }
            catch (Exception ex)
            {
                
            }
        }
        /// <summary>
        /// 循环方法
        /// </summary>
        /// <param name="symbol"></param>
        /// <param name="IsStructVar"></param>
        /// <param name="IsBaseArray"></param>
        public void AddPlcSymbols(ISymbol symbol,bool IsStructVar=false,bool IsBaseArray=false)
        {
            if (IsStructVar)
            {
                if (!symbol.InstancePath.StartsWith(".."))
                {
                    if (symbol.IsPersistent)
                    {
                        PersistantSymbols.Add(symbol);
                        PersistantVars.Add($"{symbol.InstancePath}|{symbol.DataType.Name}|{symbol.Size}");
                    }
                    else if (symbol.SubSymbols.Count<ISymbol>() > 0)
                    {
                        foreach (var item in symbol.SubSymbols)
                        {
                            AddPlcSymbols(item, IsStructVar,IsBaseArray);
                        }
                    }
                }
            }
            else
            {
                if (symbol.SubSymbols.Count<ISymbol>() > 0)
                {
                    if (IsBaseArray)
                    {
                        if (symbol.DataType is IArrayType array)
                        {
                            if (symbol.SubSymbols[0].Category == DataTypeCategory.String || symbol.SubSymbols[0].Category == DataTypeCategory.Primitive)
                            {
                                if (symbol.IsPersistent)
                                {
                                    PersistantSymbols.Add(symbol);
                                    PersistantVars.Add($"{symbol.InstancePath}|{symbol.DataType.Name}|{symbol.Size}");
                                }
                                return;
                            }
                        }
                    }

                    foreach (var item in symbol.SubSymbols)
                    {
                        AddPlcSymbols(item,IsStructVar,IsBaseArray);
                    }
                }
                else
                {
                    if (!symbol.InstancePath.StartsWith(".."))
                    {
                        if (symbol.IsPersistent)
                        {
                            PersistantSymbols.Add(symbol);
                            PersistantVars.Add($"{symbol.InstancePath}|{symbol.DataType.Name}|{symbol.Size}");
                        }
                    }
                }
            }
            
        }

