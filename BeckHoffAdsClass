        /// <summary>
        /// 读取所有断电保持型变量
        /// </summary>
        public int FromPlc(string path)
        {
            int num = 0;
            symbolValues.Clear();
            ParsePlcSymbols(true,false);

            object[] values = null;
            AdsErrorCode[] adsErrorCodes=null;
            new SumSymbolRead(tcClient, PersistantSymbols).TryRead(out values,out adsErrorCodes);
            
            for (int i = 0; i < values.Length; i++)
            {
                //字节数组：包括结构体，字节数组
                if (typeof(byte[]) == values[i].GetType())
                {
                    ParsePlcDataToString((byte[])values[i], PersistantSymbols[i]);
                }
                else
                {
                    DataType dataType = (DataType)PersistantSymbols[i].DataType;
                    //数组
                    if (dataType.Category == DataTypeCategory.Array)
                    {
                        List<string> temp = new List<string>();
                        if (values[i] is Array array)
                        {
                            foreach (var item in array)
                            {
                                temp.Add(item.ToString());
                            }
                            ParsePlcDataToArrayString(temp.ToArray(), PersistantSymbols[i]);
                        }
                    }
                    //
                    else
                    {
                        symbolValues.Add($"{PersistantSymbols[i].InstancePath}|{values[i].ToString()}");
                    }
                }
            }
            num = values.Count();
            if (!string.IsNullOrEmpty(path))
            {
                File.WriteAllLines(path, symbolValues);
            }
            return num;
            
        }
        /// <summary>
        /// 
        /// </summary>
        /// <param name="path"></param>
        /// <returns></returns>
        public int ToPlc(string path)
        {
            if (File.Exists(path))
            {
                Dictionary<string, object> keyValuePairs = new Dictionary<string, object>();
                var lines = File.ReadAllLines(path);
                for (int i = 0; i < lines.Length; i++)
                {
                    string[] splits = lines[i].Split('|');
                    string name = splits[0];
                    string value = splits[1];
                    var symbol = allSymbols[name];
                    if (symbol != null)
                    {
                        keyValuePairs.Add(name, ValueToObject(symbol, value));
                    }
                }
                return SumWrite(keyValuePairs);  
            }
            return 0;
            
        }
        public int SumWrite(Dictionary<string, object> keyValuePairs)
        {
            int num = 0;
            List<string> Symbols = keyValuePairs.Keys.ToList();
            object[] Values = keyValuePairs.Values.ToArray();
            SumSymbolWrite writeCommand = new SumSymbolWrite(tcClient, GetSymbol(Symbols));
            writeCommand.Write(Values);
            if (writeCommand.Succeeded)
            {
                num = Values.Count();
            }
            return num;
        }


