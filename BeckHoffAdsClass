        public void AddVariableMonitor(string triggerVariable,string groupName,List<string> variablesToSave)
        {
            var group = new AdsVariableGroup
            {
                Name=groupName,
                TriggerVariable = triggerVariable,
                VariablesToSave=variablesToSave,
                LastValues = new Dictionary<string, object>()
            };

            _variableGroups[groupName] = group;
            //为触发变量注册通知
            RegisterNotificationEx(triggerVariable,groupName);
        }
        /// <summary>
        /// 注册通知
        /// </summary>
        /// <param name="triggerVariable"></param>
        /// <param name="groupName"></param>
        private void RegisterNotificationEx(string triggerVariable, string groupName)
        {
            try
            {
                // 创建委托用于回调
                AdsNotificationExEventHandler callback = (sender, e) =>
                    OnVariableChanged(sender, e, groupName, triggerVariable);
             
                // 注册通知
                var notificationHandle = tcClient.AddDeviceNotificationEx(
                    triggerVariable,
                    AdsTransMode.OnChange,
                     100,    // 循环时间(ms)
                     0,      // 最大延迟(ms)
                    callback,
                    null
                );

                _variableHandles[triggerVariable] = notificationHandle;
            }
            catch (Exception ex)
            {
                string message = $"注册变量通知失败 {triggerVariable}: {ex.Message}";
            }
        }
        /// <summary>
        /// 变化执行事件
        /// </summary>
        /// <param name="sender"></param>
        /// <param name="e"></param>
        /// <param name="groupName"></param>
        /// <param name="variableName"></param>
        private void OnVariableChanged(object sender, AdsNotificationExEventArgs e, string groupName,string variableName)
        {
            if (!_variableGroups.TryGetValue(groupName,out var group))            
                return;

            try
            {
                //读取出发变量的新值
                var triggerValue = e.Value;
                //保存所有相关变量的当前值
                var savedValues = new Dictionary<string, object>();
                foreach (var variable in group.VariablesToSave)
                {
                    try
                    {
                        var value = ReadSingleSymbolStr(variable);
                        savedValues[variable] = value;
                    }
                    catch (Exception)
                    {
                        savedValues[variable] = null;
                    }
                }

                //触发事件
                var eventArgs = new VariableGroupChangedEventArgs
                {
                    GroupName = groupName,
                    TriggerVariable = group.TriggerVariable,
                    TriggerValue = triggerValue,
                    SavedValues = savedValues,
                    Timestamp = DateTime.Now
                };

                //保存到csv
                _csvService.SaveVariableGroupToCsv(eventArgs);

            }
            catch (Exception)
            {

                throw;
            }
            
        }
       

