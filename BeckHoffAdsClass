        /// <summary>
        /// 类型转换
        /// </summary>
        /// <param name="symbol"></param>
        /// <param name="value"></param>
        /// <returns></returns>
        private object ValueToObject(ISymbol symbol,string value)
        {
            object data = null;
            try
            {
                switch (symbol.TypeName)
                {
                    case "BOOL":
                        data = bool.Parse(value);
                        break;
                    case "BYTE":
                        data = byte.Parse(value);
                        break;
                    case "SINT":
                        data = sbyte.Parse(value);
                        break;
                    case "INT":
                        data = short.Parse(value);
                        break;
                    case "DINT":
                        data = int.Parse(value);
                        break;
                    case "LINT":
                        data = long.Parse(value);
                        break;
                    case "USINT":
                        data = byte.Parse(value);
                        break;
                    case "UINT":
                        data = ushort.Parse(value);
                        break;
                    case "UDINT":
                        data = uint.Parse(value);
                        break;
                    case "ULINT":
                        data = ulong.Parse(value);
                        break;
                    case "REAL":
                        data = float.Parse(value);
                        break;
                    case "LREAL":
                        data = double.Parse(value);
                        break;
                    case "WORD":
                        data = ushort.Parse(value);
                        break;
                    case "DWORD":
                        data = uint.Parse(value);
                        break;
                    case "TIME":
                    case "TIME_OF_DAY":
                    case "TOD":
                        data = TimeSpan.Parse(value);
                        break;
                    case "DATE":
                    case "DATE_AND_TIME":
                    case "DT":
                        data = DateTime.Parse(value);
                        break;
                    default:
                        if (symbol.TypeName.StartsWith("STRING") || symbol.TypeName.StartsWith("WSTRING"))
                        {
                            data = value;
                        }
                        break;
                }
            }
            catch (Exception ex)
            {
                data = ex.Message;
            }

            return data;
        }
        private object ParsePlcVariableToJs(byte[] dataBuffer, DataType dataType)
        {
            if (dataType == null) return null;
            else
            {
                //1.DataTypeId
                AdsDataTypeDescription type = Types.types.Find(t => { return t.AdsDataType.Equals(dataType.DataTypeId); });
                if (type == null)
                {
                    //2.name
                    string name = dataType.Name.Trim();
                    type = Types.types.Find(t => { return t.Names.Contains(name); });
                    if (type == null)
                    {
                        //3.正则name
                        MatchCollection match = null;
                        type = Types.types.Find(t =>
                        {
                            Regex re = new Regex(@"^(" + string.Join("|", t.Names) + ")([\\[\\(](.*)[\\)\\]])*$", RegexOptions.IgnoreCase);
                            match = re.Matches(name);
                            return match != null;
                        });
                        //4.返回
                        if (type == null)
                            return null;
                        if (type.AdsDataType == AdsDatatypeId.ADST_STRING)
                        {
                            type.Size = match[0].Groups[3] != null ? (int.Parse(match[0].Groups[3].Value) + 1) : type.Size;
                        }
                        else if (type.AdsDataType == AdsDatatypeId.ADST_WSTRING)
                        {
                            type.Size = match[0].Groups[3] != null ? (int.Parse(match[0].Groups[3].Value) * 2 + 2) : type.Size;
                        }
                    }
                }
                else
                {
                    type.Size = dataType.Size;
                }

                return type.FromBuffer(dataBuffer);
            }
        }
        private object ParsePlcVariableToJs(byte[] dataBuffer, AdsDatatypeId dataTypeId)
        {
            return Types.types.Find(t => { return t.AdsDataType.Equals(dataTypeId); }).FromBuffer(dataBuffer);
        }

        /// <summary>
        /// byte结果转换
        /// </summary>
        /// <param name="dataBuffer"></param>
        /// <param name="symbol"></param>
        private void ParsePlcDataToString(byte[] dataBuffer, ISymbol symbol)
        {
            _symbols.Clear();
            ParseSymbol(symbol);
            for (int i = 0; i < _symbols.Count; i++)
            {
                DataType dataType = (DataType)_symbols[i].DataType;
                object result = ParsePlcVariableToJs(dataBuffer.Take(dataType.ByteSize).ToArray(), dataType.DataTypeId);
                symbolValues.Add($"{_symbols[i].InstancePath}|{result}");
                dataBuffer = dataBuffer.Skip(dataType.ByteSize).ToArray();
            }
        }
        /// <summary>
        /// 数组结果转换
        /// </summary>
        /// <param name="dataBuffer"></param>
        /// <param name="symbol"></param>
        private void ParsePlcDataToArrayString(string[] dataBuffer,ISymbol symbol)
        {
            _symbols.Clear();
            ParseSymbol(symbol);
            for (int i = 0; i < _symbols.Count; i++)
            {
                symbolValues.Add($"{_symbols[i].InstancePath}:={dataBuffer[i]}");
            }
        }

       /// <summary>
       /// 获取变量所有成员
       /// </summary>
       /// <param name="symbol"></param>
        private void ParseSymbol(ISymbol symbol)
        {
            if (symbol.SubSymbols.Count<ISymbol>() > 0)
            {
                foreach (var item in symbol.SubSymbols)
                {
                    ParseSymbol(symbol);
                }
            }
            else
            {
                if (!symbol.InstancePath.StartsWith(".."))
                {
                    _symbols.Add(symbol);
                }
            }
        }
