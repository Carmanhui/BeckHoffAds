        public static List<SimpleSymbol> ReadXmlToMyISymbolList(string xmlPath)
        {
            if (!(xmlPath != ""))
            {
                return null;
            }

            List<XElement> xels = XDocument.Load(xmlPath).Root.Elements().ToList<XElement>();
            if (xels.Count>0)
            {
                List<SimpleSymbol> ls = new List<SimpleSymbol>();
                foreach (XElement item in xels)
                {
                    SimpleSymbol symbol = new SimpleSymbol();
                    try
                    {
                        symbol.Name = item.Element("Name")?.Value;
                        symbol.Type = item.Element("Type")?.Value;
                        symbol.Values = item.Element("Values")?.Value;
                        ls.Add(symbol);
                    }
                    catch (Exception)
                    {
                        return null;
                    }
                }
                return ls;
            }
            return null;
        }


        public  static string CreateXmlFile(string xmlName)
        {
            string rootDirPath = "c:\\PlcDataAutoSave(重要)";
            if (!Directory.Exists(rootDirPath))
            {
                Directory.CreateDirectory(rootDirPath);
            }

            string dayXmlFilePath;
            if (xmlName.Trim() != "")
            {
                dayXmlFilePath = rootDirPath + "\\" + xmlName + ".xml";

            }
            else
            {
                dayXmlFilePath = rootDirPath + "\\" + DateTime.Now.ToString("yyyy-MM-dd HH-mm-ss") + ".xml";
            }
            return dayXmlFilePath;
        }

        public static Dictionary<string, string> GetXmlNameDic()
        {
            string rootDirPath = "c:\\PlcDataAutoSave(重要)";
            List<FileInfo> list = (from f in new DirectoryInfo(rootDirPath).GetFiles("*.xml")
                                   orderby f.CreationTime descending
                                   select f).ToList<FileInfo>();

            Dictionary<string, string> dic = new Dictionary<string, string>();
            foreach (FileInfo path in list)
            {
                string key = Path.GetFileNameWithoutExtension(path.FullName);
                try
                {
                    dic.Add(key,path.FullName);
                }
                catch (Exception ex)
                {

                }
            }
            return dic;

        }

        private static List<string> GetFiles(string path, string[] patterns)
        {
            List<string> files = new List<string>();
            try
            {
                foreach (string pattern in patterns)
                {
                    foreach (string file in Directory.GetFiles(path,pattern))
                    {
                        files.Add(file);
                    }
                }
                foreach (string dictory in Directory.GetDirectories(path))
                {
                    files.AddRange(XmlInfo.GetFiles(dictory,patterns));
                }
            }
            catch (Exception)
            {

            }
            return files;
        }

        public static Dictionary<string, string> GetConfigSymbolInfoDic()
        {
            Dictionary<string, string> dic = null;
            try
            {
                if (File.Exists("config.xml"))
                {
                    XElement rootElt = XDocument.Load("config.xml").Root;
                    if (rootElt.Elements()!=null)
                    {
                        dic = new Dictionary<string, string>();
                        foreach (XElement element in rootElt.Elements())
                        {
                            string key = element.Attribute("Name").Value;
                            string value = element.Value.ToLower();
                            dic.Add(key,value);
                        }
                    }
                }
            }
            catch (Exception)
            {
                return null;
            }
            return dic;
        }
