        public static void DeleteOldXmlFile()
        {
            try
            {
                string path = "";
                FileInfo[] fileInfos = new DirectoryInfo(path).GetFiles("*.xml");
                if (fileInfos.Length>100)
                {
                    File.Delete((from f in fileInfos
                                 orderby f.CreationTime descending
                                 select f).Last<FileInfo>().FullName);
                }
            }
            catch (Exception ex)
            {
                string message = ex.Message;
            }
        }

        public static bool SaveXmlFile(List<MySymbol> symbols, string xmlName)
        {
            bool result;
            try
            {
                if (symbols != null)
                {
                    if (symbols.Count > 0)
                    {
                        XDocument doc = new XDocument();
                        XDeclaration dec = new XDeclaration("1.0", "GB2312", "yes");
                        doc.Declaration = dec;
                        XElement rootElement = new XElement("Parameter");
                        doc.Add(rootElement);
                        foreach (MySymbol item in symbols)
                        {
                            XElement symbolElt = new XElement("Symbol");
                            symbolElt.SetAttributeValue("Name", item.Path);
                            foreach (PropertyInfo propertyInfo in item.GetType().GetProperties())
                            {
                                XElement elt = new XElement(propertyInfo.Name);
                                object val = propertyInfo.GetValue(item, null);
                                elt.Value = Convert.ToString(val);
                                symbolElt.Add(elt);
                            }
                            rootElement.Add(symbolElt);
                        }
                        doc.Save(XmlInfo.CreateXmlFile(xmlName));
                        result = true;
                    }
                    else
                    {
                        result = false;
                    }
                }
                else
                {
                    result = false;
                }
            }
            catch (Exception ex)
            {
                
                result = false;
            }
            return result;
        }

